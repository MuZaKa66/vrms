class RecordingScreen(QWidget):
    """
    Main recording interface with voice command support and professional UI.
    
    This screen provides:
    - Real-time video preview with status placeholders
    - Recording controls with keyboard shortcuts
    - Metadata management (Add/Edit/Clear)
    - Storage monitoring with warnings
    - Voice mode for hands-free operation
    
    Signals:
        recording_started: Emitted when recording begins
        recording_stopped: Emitted when recording ends (with path)
        error_occurred: Emitted on any error (for parent handling)
    """
    
    # Custom signals for parent communication
    recording_started = pyqtSignal()
    recording_stopped = pyqtSignal(str)  # Emits file path
    error_occurred = pyqtSignal(str)     # Emits error message
    
