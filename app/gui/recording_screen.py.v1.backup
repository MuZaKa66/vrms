        """Design tokens - modify these to change the entire UI."""
        
        # Spacing scale (8px grid)
        SPACING = {
            'xs': 4,    # Extra small
            'sm': 8,    # Small
            'md': 16,   # Medium
            'lg': 24,   # Large
            'xl': 32,   # Extra large
            'xxl': 48,  # 2x large
        }
        
        # Colors (semantic naming)
        COLORS = {
            'success': '#27ae60',
            'success_hover': '#229954',
            'success_pressed': '#1e8449',
            
            'danger': '#e74c3c',
            'danger_hover': '#c0392b',
            'danger_pressed': '#a93226',
            
            'info': '#5dade2',
            'info_hover': '#3498db',
            'info_pressed': '#2980b9',
            
            'warning': '#f39c12',
            'warning_hover': '#e67e22',
            'warning_bg': '#fef5e7',
            
            'text_primary': '#2c3e50',
            'text_secondary': '#7f8c8d',
            'text_light': '#ecf0f1',
            
            'background': '#ecf0f1',
            'background_dark': '#bdc3c7',
            'border': '#34495e',
            
            'preview_bg': '#2c3e50',
        }
        
        # Component sizes
        SIZES = {
            'preview': (280, 210),           # Width, Height
            'preview_min': (200, 150),
            'preview_max': (400, 300),
            
            'record_button': (340, 200),      # Start/Stop button
            'record_button_min': (200, 120),
            'record_button_max': (500, 300),
            
            'info_button': (200, 55),
            'info_button_height': 55,
            
            'storage_bar_height': 40,
            'timer_font': 48,
            'status_font': 20,
            'button_font': 24,
            'label_font': 11,
        }
        
        # Timing constants (milliseconds)
        TIMINGS = {
            'storage_check': 30000,           # Check disk every 30 seconds
            'timer_update': 100,               # Update timer every 100ms
            'dot_blink': 500,                  # Blink every 500ms
            'status_clear': 3000,              # Clear status after 3 seconds
            'preview_throttle': 3,              # Show every 3rd frame (~3-4 fps)
            'countdown': 3000,                  # 3 second countdown
            'undo_timeout': 5000,               # Show undo for 5 seconds
            'confirmation_delay': 1500,          # Show success for 1.5 seconds
        }
        
        # Recording thresholds (seconds)
        THRESHOLDS = {
            'min_recording': 3,                 # <3s: ask to discard
            'confirm_until': 30,                 # 3-30s: confirm save
            'auto_save_after': 30,                # >30s: save silently
        }
        
        # Preview states
        PREVIEW_STATES = {
            'no_camera': "📷 No Camera Detected\nCheck connection",
            'loading': "⏳ Initializing Camera...",
            'error': "⚠ Camera Error\nCheck permissions",
            'disabled': "📹 Camera Disabled",
            'ready': "📷 Camera Ready\nStart recording to see preview",
            'countdown': "",  # Dynamic
            'saved': "✓ Saved\nDuration: {duration}\nSize: {size}",
        }
    
    # =========================================================================
    # INITIALIZATION
    # =========================================================================
    
    def __init__(self, parent=None):
        """Initialize the recording screen with all components."""
        super().__init__(parent)
        
        # Core components
        self.controller = RecordingController()
        self.metadata = RecordingMetadata()
        self.voice_mode_active = False
        self.recording_start_time = None
        self.last_recording_path = None
        
        # Preview optimization (Fixes SNo 7)
        self.frame_counter = 0
        self.preview_skip_target = self.Design.TIMINGS['preview_throttle']
        self.preview_buffer = None
        self.last_preview_time = 0
        
        # State tracking
        self.emergency_stop = False
        self._cleaned_up = False
        self.dot_visible = True
        
        # Connect error callback from controller
        self.controller.set_error_callback(self._handle_recording_error)
        
        # Initialize UI
        self._setup_ui()
        self._setup_shortcuts()  # Fixes SNo 13
        self._start_storage_monitoring()  # Fixes SNo 3
        
        # Initial preview state
        self._check_camera_status()
        
        logger.info("RecordingScreen v4.0.1 initialized (patched for existing codebase)")
    
