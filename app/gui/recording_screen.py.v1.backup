    def _create_storage_bar(self) -> QFrame:
        """Create the storage usage bar with styling."""
        frame = QFrame()
        frame.setStyleSheet("QFrame { background-color: #ecf0f1; border-radius: 5px; }")
        
        layout = QHBoxLayout(frame)
        layout.setContentsMargins(10, 5, 10, 5)
        
        # Storage label
        label = QLabel("Storage:")
        label.setFont(QFont("Arial", 12, QFont.Bold))
        layout.addWidget(label)
        
        # Progress bar
        self.storage_bar = QProgressBar()
        self.storage_bar.setMinimum(0)
        self.storage_bar.setMaximum(100)
        self.storage_bar.setValue(0)
        self.storage_bar.setFormat("Calculating...")
        self.storage_bar.setStyleSheet("""
            QProgressBar {
                border: 2px solid #bdc3c7;
                border-radius: 5px;
                text-align: center;
                height: 30px;
            }
            QProgressBar::chunk { background-color: #27ae60; }
        """)
        
        layout.addWidget(self.storage_bar)
        
        return frame
    
    def _create_preview_container(self) -> QFrame:
        """Create the preview container with recording indicator."""
        container = QFrame()
        
        layout = QVBoxLayout(container)
        layout.setContentsMargins(0, 0, 10, 0)  # Right margin
        layout.setSpacing(3)
        
        # Recording indicator with HTML dot (Fixes SNo 5)
        self.recording_indicator = QLabel()
        self.recording_indicator.setFont(QFont("Arial", 10, QFont.Bold))
        self.recording_indicator.setTextFormat(Qt.RichText)
        self._update_recording_indicator(visible=False)
        self.recording_indicator.setAlignment(Qt.AlignLeft)
        layout.addWidget(self.recording_indicator)
        
        # Preview label
        self.preview_label = QLabel()
        preview_size = self.Design.SIZES['preview']
        self.preview_label.setFixedSize(preview_size[0], preview_size[1])
        # Fixed: Removed setMinimumSize and setMaximumSize - they conflict with setFixedSize
        # and cause Qt to ignore the fixed size, allowing preview to collapse
        self.preview_label.setStyleSheet(f"""
            QLabel {{
                background-color: {self.Design.COLORS['preview_bg']};
                border: 2px solid {self.Design.COLORS['border']};
                border-radius: 5px;
                color: {self.Design.COLORS['text_light']};
            }}
        """)
        self.preview_label.setAlignment(Qt.AlignCenter)
        
        # Initialize preview buffer (Fixes SNo 14)
        self.preview_buffer = QPixmap(preview_size[0], preview_size[1])
        self.preview_buffer.fill(QColor(self.Design.COLORS['preview_bg']))
        self.preview_label.setPixmap(self.preview_buffer)
        
        layout.addWidget(self.preview_label)
        
        return container
    
